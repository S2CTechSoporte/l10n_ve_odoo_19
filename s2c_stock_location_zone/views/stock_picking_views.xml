<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_picking_tree_inherit" model="ir.ui.view">
            <field name="name">stock.picking.tree.s2c_stock_location_zone</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="city" optional="show"/>
                    <field name="municipality_id" optional="show"/>
                    <field name="state_id" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="view_picking_search_inherit" model="ir.ui.view">
            <field name="name">stock.picking.search.s2c_stock_location_zone</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_internal_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="state_id"/>
                    <field name="city"/>
                    <field name="municipality_id"/>
                </xpath>
                <xpath expr="//filter[@name='internal']" position="after">
                    <separator/>
                </xpath>
                <xpath expr="//group[not(@name)]" position="inside">
                    <filter string="Estado" name="state_id" domain="[]" context="{'group_by': 'state_id'}"/>
                    <filter string="Ciudad" name="city" domain="[]" context="{'group_by': 'city'}"/>
                    <filter string="Municipio" name="municipality_id" domain="[]" context="{'group_by': 'municipality_id'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>