<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_move_line_tree_inherit" model="ir.ui.view">
            <field name="name">stock.move.line.tree.s2c_stock_location_zone</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_move_line_tree_detailed"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_partner_id']" position="after">
                    <field name="state_id" optional="show"/>
                    <field name="city" optional="show"/>
                    <field name="municipality_id" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="view_stock_move_line_search_inherit" model="ir.ui.view">
            <field name="name">stock.move.line.search.s2c_stock_location_zone</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.stock_move_line_view_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_id']" position="after">
                    <field name="state_id"/>
                    <field name="city"/>
                    <field name="municipality_id"/>
                </xpath>
                <xpath expr="//group[@name='groupby']" position="inside">
                    <filter string="Estado" name="by_state_id" domain="[]" context="{'group_by': 'state_id'}"/>
                    <filter string="Ciudad" name="by_city" domain="[]" context="{'group_by': 'city'}"/>
                    <filter string="Municipio" name="by_municipality_id" domain="[]" context="{'group_by': 'municipality_id'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>