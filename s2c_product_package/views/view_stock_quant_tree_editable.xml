<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>   
        <!-- ubicaciones: -->
        <record  id="view_stock_quant_product_package" model="ir.ui.view">
            <field name="name">stock.quant.product.package</field>
            <field name="model">stock.quant</field>
            <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"></field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='reserved_quantity']" position="after">
                    <field name="packaging_name" optional="show" />
                    <field name="packaging_qty_available" optional="show" />
                    <field name="packaging_reserved_qty" optional="show" />
                    <field name="volume_available" optional="show" />
                    <field name="weight_available" optional="show" />
                </xpath>
                
            </field>
        </record>
    </data>
</odoo>
