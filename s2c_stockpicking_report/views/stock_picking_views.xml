<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="s2c_stockpicking_report_stock_picking_form_inherit" model="ir.ui.view">
            <field name="name">stock.picking.form.s2c_stockpicking_report</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_put_in_pack']" position="before">
                    <div class="o_row">
                        <group>
                            <field name="packages_count" readonly="1"/>
                            <field name="shipping_weight" readonly="1"/>
                        </group>
                    </div>
                </xpath>
                <xpath expr="//button[@name='action_cancel']" position="before">
                    <button string="Imprimir Etiquetas Bultos" type="object" 
                        name="action_print_label_bags" invisible="not packages_count"/>
                </xpath>

                <notebook position="inside">
                    <page string="Información de Entrega" name="extra">
                        <group>
                            <group string="Datos de Despacho" name="shipping_infos">
                                <field name="packages_count" readonly="1"/>
                                <field name="shipping_weight" readonly="1"/>
                            </group>

                            <group string="Datos del Conductor" name="other_infos">
                                <field name="name_driver" readonly="state in ('done', 'cancel')"/>
                                <field name="identification_driver"  readonly="state in ('done', 'cancel')"/>
                            </group>

                            <group string="Datos del Vehículo" name="other_infos">
                                <field name="vehicle"  readonly="state in ('done', 'cancel')"/>
                                <field name="license_plate" readonly="state in ('done', 'cancel')"/>
                                <field name="vehicle_brand" readonly="state in ('done', 'cancel')"/>
                                <field name="vehicle_type" readonly="state in ('done', 'cancel')"/>
                            </group>
                            
                        </group>
                    </page>
                </notebook>
            </field>
        </record>

        <record id="s2c_stockpicking_report_stock_picking_search_inherit" model="ir.ui.view">
            <field name="name">stock.picking.search.s2c_stockpicking_report</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_internal_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="state_id"/>
                    <field name="city"/>
                    <field name="municipality_id"/>
                </xpath>
                <xpath expr="//filter[@name='internal']" position="after">
                    <separator/>
                </xpath>
                <xpath expr="//group[not(@name)]" position="inside">
                    <filter string="Estado" name="state_id" domain="[]" context="{'group_by': 'state_id'}"/>
                    <filter string="Ciudad" name="city" domain="[]" context="{'group_by': 'city'}"/>
                    <filter string="Municipio" name="municipality_id" domain="[]" context="{'group_by': 'municipality_id'}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>