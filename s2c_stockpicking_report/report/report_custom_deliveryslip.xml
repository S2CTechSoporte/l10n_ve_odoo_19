<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_custom_deliveryslip_template">
        <t t-call="web.html_container">
			<t t-call="web.basic_layout">
				<t t-foreach="docs" t-as="doc">
					<t t-set="lang" t-value="doc.partner_id.lang"/>
					<t t-set="o" t-value="doc.with_context(lang=lang)"/>
                    <div style="height: 35mm" />
                    <div class="hearder" style="font-size: 8pt;">
                        <div class="row">
                            <div class="col-8"/>
                            <div class="col-4 text-end">
                                <table class="table table-borderless p-0 m-0" width="100%">
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Traslado Nro:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Fecha:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.date_done" t-options='{"widget": "date"}' />
                                        </td>
                                    </tr>
                                </table>

                            </div>
                        </div>
                        <div id="location_id" class="row">
                            <div class="col-12">
                                <table width="100%" class="table table-borderless p-0 m-0">
                                    <tr>
                                        <td width="20%" class="p-0 m-0">
                                            <strong>Almacen Emisor:</strong>
                                        </td>
                                        <td width="80%" class="p-0 m-0">
                                            <span t-field="o.location_id.warehouse_id"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Dirección</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-if="o.location_id.warehouse_id.partner_id.street" t-field="o.location_id.warehouse_id.partner_id.street"/> 
                                            <span t-if="o.location_id.warehouse_id.partner_id.street2" t-field="o.location_id.warehouse_id.partner_id.street2"/>
                                            <span t-if="o.location_id.warehouse_id.partner_id.city" t-field="o.location_id.warehouse_id.partner_id.city"/>
                                            <span t-if="o.location_id.warehouse_id.partner_id.state_id" t-field="o.location_id.warehouse_id.partner_id.state_id"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Almacen Receptor:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.location_dest_id.warehouse_id"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Dirección:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-if="o.location_dest_id.warehouse_id.partner_id.street" t-field="o.location_dest_id.warehouse_id.partner_id.street"/> 
                                            <span t-if="o.location_dest_id.warehouse_id.partner_id.street2" t-field="o.location_dest_id.warehouse_id.partner_id.street2"/>
                                            <span t-if="o.location_dest_id.warehouse_id.partner_id.city" t-field="o.location_dest_id.warehouse_id.partner_id.city"/>
                                            <span t-if="o.location_dest_id.warehouse_id.partner_id.state_id" t-field="o.location_dest_id.warehouse_id.partner_id.state_id"/>
                                        </td>
                                    </tr>
                                </table>

                                <table width="100%" class="table table-borderless p-0 m-0">
                                    <tr>
                                        <td width="20%" class="p-0 m-0">
                                            <strong>Chofer:</strong>
                                        </td>
                                        <td width="15%" class="p-0 m-0">
                                            <span t-field="o.name_driver"/> 
                                        </td>
                                        <td width="15%" class="p-0 m-0">
                                            <strong>Cédula:</strong>
                                        </td>
                                        <td width="15%" class="p-0 m-0">
                                            <span t-field="o.identification_driver"/> 
                                        </td>
                                        <td width="15%" class="p-0 m-0">
                                            <strong>Vehículo:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.vehicle"/> 
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="p-0 m-0">
                                            <strong>Marca:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.vehicle_brand"/> 
                                        </td>
                                        <td class="p-0 m-0">
                                            <strong>Placas:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.license_plate"/> 
                                        </td>
                                        <td class="p-0 m-0">
                                            <strong>Tipo:</strong>
                                        </td>
                                        <td class="p-0 m-0">
                                            <span t-field="o.vehicle_type"/> 
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="page" style="font-size: 8pt;">
                        <div class="row border-dark border-bottom border-top pt-2 pb-2 px-0 mx-0">
                            <div class="col-2 px-0 mx-0"><b>CODIGO</b></div>
                            <div class="col-6 px-0 mx-0"><b>DESCRIPCIÓN</b></div>
                            <div class="col-2 px-0 mx-0"><b>PRESENTACION</b></div>
                            <div class="col-2 px-0 mx-0"><b>CANTIDAD</b></div>
                        </div>
                        <t t-set="i" t-value="0"/>
                        <t t-set="page" t-value="1"/>
                        <t t-set="moves" t-value="o.move_ids.filtered(lambda move: move.quantity and any(not ml.is_entire_pack for ml in move.move_line_ids))"/>
                        <t t-foreach="moves.sorted(key=lambda move: ((move.move_line_ids and move.move_line_ids[0].location_id.complete_name) or move.location_id.complete_name, (move.move_line_ids and move.move_line_ids[0].location_dest_id.complete_name) or move.location_dest_id.complete_name))" t-as="ml">
                            <t t-set="i" t-value="i + 1"/>
                            <div class="row border-dark px-0 mx-0">
                                <div class="col-2"><!-- <td t-if="has_serial_number" class="text-center h6" width="15%"> -->
                                        <span t-field="ml.product_id.default_code"/>
                                </div>
                                <div class="col-6"> <!-- 2. products -->
                                    <span t-field="ml.product_id.name"/>
                                </div>
                                
                                <div class="col-2"> <!-- 4. empaquetado -->
                                    <t t-if="ml.product_packaging_id">
                                        <span t-field="ml.product_packaging_id.name"/>
                                    </t>
                                    <t t-else="">
                                        <span t-field="ml.product_id.uom_id"/>
                                    </t>
                                </div>
                                <div class="col-2 text-end"> <!-- 7. Package -->
                                    <span t-field="ml.packaging_quantity" t-options='{"widget": "float", "precision": 2}'/>
                                </div>
                            </div>

                            <t t-if="(page==1 and i==36) or (page!=1 and i==46)">
                                <t t-set="i" t-value="0"/>
                                <t t-set="page" t-value="page + 1"/>
                                <hr />
                                <div class="row border-dark px-0 mx-0" style="page-break-after: always;"/>
                                <div style="height: 3.5cm" />
                                <div class="row border-dark border-bottom border-top pt-2 pb-2 px-0 mx-0">
                                    <div class="col-2 px-0 mx-0"><b>CODIGO</b></div>
                                    <div class="col-6 px-0 mx-0"><b>DESCRIPCIÓN</b></div>
                                    <div class="col-2 px-0 mx-0"><b>PRESENTACION</b></div>
                                    <div class="col-2 px-0 mx-0"><b>CANTIDAD</b></div>
                                </div>
                            </t>
                        </t>
                        <div class="row border-dark border-top px-0 mx-0" >
                            <div class="col-12 px-0 mx-0">
                                <span t-esc="' '"/>
                            </div>
                        </div>
                    </div>

                </t>
               
            </t>
        </t>
    </template>
</odoo>
