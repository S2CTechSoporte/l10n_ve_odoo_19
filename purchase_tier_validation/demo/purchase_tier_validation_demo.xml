<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="user_purchase_tier_validation_demo_reviewer" model="res.users">
        <field name="name">Purchase Tier Demo Reviewer</field>
        <field name="login">purchase_tier_validation_demo_reviewer</field>
        <field name="email">purchase-tier-demo@example.com</field>
        <field
            name="group_ids"
            eval="[(6, 0, [ref('base.group_user'), ref('purchase.group_purchase_manager')])]"
        />
    </record>

    <record id="partner_purchase_tier_validation_demo_vendor" model="res.partner">
        <field name="name">Purchase Tier Demo Vendor</field>
        <field name="email">purchase-tier-vendor@example.com</field>
        <field name="company_type">company</field>
        <field name="people_type_company">pjnd</field>
        <field name="supplier_rank">1</field>
    </record>

    <record id="product_purchase_tier_validation_demo" model="product.product">
        <field name="name">Purchase Tier Demo Product</field>
        <field name="standard_price">120.0</field>
    </record>

    <record id="tier_definition_purchase_tier_validation_demo" model="tier.definition">
        <field name="name">Purchase Tier Demo Approval</field>
        <field name="model_id" ref="purchase.model_purchase_order" />
        <field name="review_type">individual</field>
        <field name="reviewer_id" ref="user_purchase_tier_validation_demo_reviewer" />
        <field name="definition_domain">[('amount_untaxed', '&gt;', 50.0)]</field>
    </record>

    <record id="purchase_order_tier_validation_demo_order" model="purchase.order">
        <field name="partner_id" ref="partner_purchase_tier_validation_demo_vendor" />
        <field
            name="order_line"
            eval="[(0, 0, {
                'name': 'Purchase Tier Demo Line',
                'product_id': ref('product_purchase_tier_validation_demo'),
                'product_qty': 1.0,
                'product_uom_id': ref('uom.product_uom_unit'),
                'price_unit': 120.0,
                'date_planned': '2026-06-28 10:00:00',
            })]"
        />
    </record>
</odoo>