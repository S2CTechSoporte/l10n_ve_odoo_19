#. module: s2c_financial_risk_overdue
#: model:ir.model.fields,field_description:s2c_financial_risk_overdue.field_res_partner__risk_account_overdue_invoices
#: model:ir.model.fields,field_description:s2c_financial_risk_overdue.field_res_users__risk_account_overdue_invoices
msgid "Block Sales With Overdue Invoices"
msgstr "Bloquear ventas con facturas vencidas"

#. module: s2c_financial_risk_overdue
#: model:ir.model.fields,help:s2c_financial_risk_overdue.field_res_partner__risk_account_overdue_invoices
#: model:ir.model.fields,help:s2c_financial_risk_overdue.field_res_users__risk_account_overdue_invoices
