#: model:ir.model.fields,field_description:s2c_financial_risk_overdue.field_res_users__risk_amount_overdue_invoices
msgid "Overdue Customer Invoices"
msgstr "Facturas de cliente vencidas"

#. module: s2c_financial_risk_overdue
#: model:ir.model.fields,help:s2c_financial_risk_overdue.field_res_partner__risk_amount_overdue_invoices
#: model:ir.model.fields,help:s2c_financial_risk_overdue.field_res_users__risk_amount_overdue_invoices
msgid "Pending balance of overdue customer invoices."
msgstr "Saldo pendiente de las facturas de cliente vencidas."

#. module: s2c_financial_risk_overdue
msgid "This customer has overdue invoices.\n"
msgstr "Este cliente tiene facturas vencidas.\n"