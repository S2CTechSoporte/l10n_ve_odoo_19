<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="partner_demo_financial_risk_overdue" model="res.partner">
            <field name="name">Overdue Risk Demo Customer</field>
            <field name="customer_rank">1</field>
            <field name="risk_account_overdue_invoices">True</field>
        </record>

        <record id="invoice_demo_financial_risk_overdue" model="account.move">
            <field name="move_type">out_invoice</field>
            <field name="partner_id" ref="s2c_financial_risk_overdue.partner_demo_financial_risk_overdue"/>
            <field name="invoice_date">2026-05-01</field>
            <field name="date">2026-05-01</field>
            <field name="invoice_date_due">2026-05-10</field>
            <field name="journal_id" search="[('type', '=', 'sale'), ('company_id', '=', ref('base.main_company'))]"/>
        </record>

        <record id="invoice_demo_financial_risk_overdue_line" model="account.move.line">
            <field name="move_id" ref="s2c_financial_risk_overdue.invoice_demo_financial_risk_overdue"/>
            <field name="name">Overdue financial risk demo line</field>
            <field name="quantity">1.0</field>
            <field name="price_unit">250.0</field>
            <field name="account_id" search="[('account_type', 'in', ['income', 'income_other']), ('company_ids', 'child_of', ref('base.main_company'))]"/>
        </record>
    </data>
</odoo>