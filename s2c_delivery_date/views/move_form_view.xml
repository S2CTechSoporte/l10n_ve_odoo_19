<?xml version="1.0" encoding="utf-8"?>
<odoo>        
    <!-- journal entry Inherit Form View to Modify it -->
    <record id="view_move_form_s2c_inherit" model="ir.ui.view">
        <field name="name">view.move.form.s2c.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            
            <xpath expr="//group[@name='sale_info_group']/field[@name='delivery_date']" position="replace">
                <field name="delivery_date" string="Fecha entrega al Cliente"  widget="date" readonly="payment_state == 'paid'"/>

                <label for="delivery_time" string="Tiempo de Entrega" />
                <div name="delivery_time_div" class="d-flex">
                   <field name="delivery_time" style="width: 30px"/> <span class="oe_inline o_form_label mx-1">  días </span>
                </div>
                
            </xpath>
        </field>
    </record>
</odoo>