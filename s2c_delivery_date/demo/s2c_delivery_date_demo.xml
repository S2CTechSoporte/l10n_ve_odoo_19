<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="partner_demo_delivery_date" model="res.partner">
            <field name="name">Delivery Date Demo Customer</field>
            <field name="customer_rank">1</field>
            <field name="property_payment_term_id" ref="account.account_payment_term_30days"/>
        </record>

        <record id="invoice_demo_delivery_date" model="account.move">
            <field name="move_type">out_invoice</field>
            <field name="partner_id" ref="s2c_delivery_date.partner_demo_delivery_date"/>
            <field name="invoice_date">2026-04-01</field>
            <field name="delivery_date">2026-04-11</field>
            <field name="invoice_payment_term_id" ref="account.account_payment_term_30days"/>
            <field name="journal_id" search="[('type', '=', 'sale'), ('company_id', '=', ref('base.main_company'))]"/>
        </record>

        <record id="invoice_demo_delivery_date_line" model="account.move.line">
            <field name="move_id" ref="s2c_delivery_date.invoice_demo_delivery_date"/>
            <field name="name">Consulting service billed from delivery date</field>
            <field name="quantity">1.0</field>
            <field name="price_unit">250.0</field>
            <field name="account_id" search="[('account_type', 'in', ['income', 'income_other']), ('company_ids', 'child_of', ref('base.main_company'))]"/>
        </record>

        <record id="invoice_demo_invoice_date_reference" model="account.move">
            <field name="move_type">out_invoice</field>
            <field name="partner_id" ref="s2c_delivery_date.partner_demo_delivery_date"/>
            <field name="invoice_date">2026-04-01</field>
            <field name="delivery_date">2026-04-01</field>
            <field name="invoice_payment_term_id" ref="account.account_payment_term_30days"/>
            <field name="journal_id" search="[('type', '=', 'sale'), ('company_id', '=', ref('base.main_company'))]"/>
        </record>

        <record id="invoice_demo_invoice_date_reference_line" model="account.move.line">
            <field name="move_id" ref="s2c_delivery_date.invoice_demo_invoice_date_reference"/>
            <field name="name">Reference invoice using the invoice date</field>
            <field name="quantity">1.0</field>
            <field name="price_unit">180.0</field>
            <field name="account_id" search="[('account_type', 'in', ['income', 'income_other']), ('company_ids', 'child_of', ref('base.main_company'))]"/>
        </record>
    </data>
</odoo>